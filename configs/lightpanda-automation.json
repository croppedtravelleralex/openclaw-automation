{
  "id": "lightpanda-automation",
  "root": "/root/SelfMadeprojects/lightpanda-automation",
  "enabled": true,
  "default_execute": true,
  "collect_data": true,
  "report_every_rounds": 10,
  "report_policy": "hybrid",
  "confirmation_points": [
    "architecture_decision",
    "external_push",
    "destructive_change",
    "heavy_install",
    "repeated_failure"
  ],
  "vision_path": "VISION.md",
  "direction_path": "CURRENT_DIRECTION.md",
  "todo_path": "TODO.md",
  "status_path": "STATUS.md",
  "progress_path": "PROGRESS.md",
  "action_commands": {
    "bug_fix": "cargo test -q"
  },
  "action_command_overrides": {
    "推进 verify / smoke / batch verify 质量闭环": "cargo test -q",
    "继续推进 trust score 核心化": "printf '[shadow-plan] trust score core queued\\n' >> EXECUTION_LOG.md"
  }
}
